// vim: set ft=jsonc:
// Niri-specific bar config; niri's spawn-at-startup launches waybar with -c
// pointing here. Inherits modules-right and all module definitions from
// config.jsonc via include (keys defined in this file take precedence).
// Swaps the sway modules for their niri equivalents and drops the sway
// scratchpad indicators, which have no niri counterpart.
{
    "include": ["{{ .chezmoi.homeDir }}/.config/waybar/config.jsonc"],
    "modules-left": [
        "niri/workspaces"
    ],
    "modules-center": [
        "niri/window"
    ],
    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
{{- if ne .chezmoi.hostname "trebek" }}
            // Named workspaces: s = Spotify, n = Obsidian (same icons as the
            // old sway scratchpad indicators). trebek has no named workspaces.
            "s": "",
            "n": "",
{{- end }}
            // Dynamic workspaces render as anonymous dots: filled bullet
            // when occupied, hollow when empty. Plain-text glyphs (not Nerd
            // Font PUA icons) so they center properly in the button.
            "empty": "○",
            "default": "●"
        }
    }
}
