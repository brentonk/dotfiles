// vim: set ft=jsonc:
{
    // "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": {{ if eq .chezmoi.hostname "trebek" }}30{{ else }}35{{ end }}, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/scratch-other",
        "custom/scratch-spotify",
        "custom/scratch-obsidian",
        "custom/scratch-claude",
        "custom/scratch-wezterm",
        "custom/media"
    ],
    "modules-center": [
        {{ if ne .chezmoi.hostname "trebek" -}}
        "sway/window"
        {{- end }}
    ],
    "modules-right": [
        "custom/gcal",
        "network",
        {{ if or (eq .chezmoi.hostname "ASLNX-24CXCB4") (eq .chezmoi.hostname "milchick") -}}
        "custom/spotify",
        "pulseaudio",
        {{- end }}
        {{ if eq .chezmoi.hostname "trebek" -}}
        "battery",
        {{- else -}}
        "cpu",
        "memory",
        "temperature",
        {{- end}}
        "clock",
        "tray",
        "custom/swaync"
    ],
    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },
    "custom/gcal": {
      "exec": "{{ .chezmoi.homeDir }}/Dropbox/bin/gcal_waybar.py",
      "interval": 60,
      "return-type": "text",
      "show-empty": false
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "",
            "unlocked": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    // Generic scratchpad counter, excluding the dedicated spotify/obsidian
    // scratchpads below (they have their own indicators)
    "custom/scratch-other": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scratchpad_count.sh '\uf2d2'",
        "on-click": "swaymsg scratchpad show",
        "restart-interval": 1
    },
    // Dedicated scratchpad indicators (see sway config $mod+s/$mod+o)
    "custom/scratch-spotify": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scratchpad_indicator.sh spotify ''",
        "on-click": "swaymsg '[app_id=\"spotify\"] scratchpad show' || swaymsg '[class=\"Spotify\"] scratchpad show' || spotify",
        "restart-interval": 1
    },
    "custom/scratch-obsidian": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scratchpad_indicator.sh obsidian ''",
        "on-click": "swaymsg '[app_id=\"obsidian\"] scratchpad show' || {{ if eq .chezmoi.hostname "ASLNX-24CXCB4" }}$HOME/.local/bin/Obsidian-1.12.4.AppImage --no-sandbox --ozone-platform=wayland{{ else }}obsidian --no-sandbox --ozone-platform=wayland{{ end }}",
        "restart-interval": 1
    },
    "custom/scratch-claude": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scratchpad_indicator.sh claude-desktop ''",
        "on-click": "swaymsg '[app_id=\"claude-desktop\"] scratchpad show' || claude-desktop",
        "restart-interval": 1
    },
    "custom/scratch-wezterm": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scratchpad_indicator.sh wezterm-scratch ''",
        "on-click": "swaymsg '[app_id=\"wezterm-scratch\"] scratchpad show' || wezterm start --class wezterm-scratch",
        "restart-interval": 1
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ⸨{songPosition}|{queueLength}⸩ {volume}% ",
        "format-disconnected": "Disconnected ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": " "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\"></span> ",
            "on": " "
        },
        "repeat-icons": {
            "on": " "
        },
        "single-icons": {
            "on": "1 "
        },
        "state-icons": {
            "paused": "",
            "playing": ""
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    // Notification indicator (swaync), macOS-style crescent moon (nf-fa-moon,
    // U+F186). Left-click toggles the notification panel, right-click toggles
    // do-not-disturb. Turns red/accent when there are unread notifications.
    "custom/swaync": {
        "tooltip": true,
        "format": "{icon}",
        // Same moon glyph for every state; the color for unread/dnd states is
        // set in style.css (not inline pango) so the glyph inherits the pinned
        // Iosevka Nerd Font that actually carries U+F186.
        "format-icons": {
            "notification": "",
            "none": "",
            "dnd-notification": "",
            "dnd-none": "",
            "inhibited-notification": "",
            "inhibited-none": "",
            "dnd-inhibited-notification": "",
            "dnd-inhibited-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
        // "icons": {
        //   "blueman": "bluetooth",
        //   "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        // }
    },
    "clock": {
        // "timezone": "America/New_York",
        "format": "{:%a %Y-%m-%d %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "{usage}% ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% "
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}°C {icon}",
        "format": "{temperatureC}°C {icon}",
        "format-icons": ["", "", ""]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["", "", "", "", "", "", "", "", ""]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "",
        "performance": "",
        "balanced": "",
        "power-saver": ""
      }
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ",
        "format-ethernet": "{ipaddr}/{cidr} ",
        "tooltip-format": "{ifname} via {gwaddr} ",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "Disconnected ⚠",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "",
            "default": "🎜"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/spotify": {
        "format": "{}",
        "return-type": "text",
        "interval": 3,
        "escape": true,
        "exec": "$HOME/.config/waybar/spotify.sh",
        "on-click": "playerctl --player=spotify play-pause"
    },
    "custom/power": {
        "format" : "⏻ ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate"
		}
    }
}
