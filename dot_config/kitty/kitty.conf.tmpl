# vim: ft=conf:

# Hostname: {{ .chezmoi.hostname }}

# Defaults for every host; per-host font/size/opacity deviations live in
# kitty.local.conf (not chezmoi-managed) -- see CLAUDE.md for each host's values.
font_family	JetBrainsMono NF Thin
italic_font	JetBrainsMono NF Thin Italic
bold_font	JetBrainsMono NF Light
bold_italic_font	JetBrainsMono NF Light Italic
font_size	11.5

# Window margins
window_padding_width 8

# Theming
background_opacity 0.95
dynamic_background_opacity yes
{{- if eq .chezmoi.os "linux" }}

# Remote control socket, used by the compositor opacity-toggle script
# (~/.config/niri/scripts/toggle_opacity.sh). One socket per kitty process.
allow_remote_control socket-only
listen_on unix:${XDG_RUNTIME_DIR}/kitty-{kitty_pid}.sock
{{- end }}

# Ctrl-shift-n opens new kitty window in the current working directory
map ctrl+shift+n launch --cwd=current --type=os-window

# Treat option as alt on Mac
macos_option_as_alt yes


# BEGIN_KITTY_THEME
# Flexoki Dark
include current-theme.conf
# END_KITTY_THEME

# Per-host local overrides (font_size, background_opacity, ...).
# Not chezmoi-managed; globinclude is silently ignored when the file is absent.
globinclude kitty.local.conf
