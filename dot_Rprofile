options(repos = structure(c(CRAN = "https://cloud.r-project.org/")))

# Default graphics device: httpgd, viewed in a bar-less chromium app window
# (mirrors ~/.config/fish/quarto-app-browser/xdg-open). Falls back to R's
# normal default device on machines without httpgd.
#
# NB: if you close the chromium window without dev.off(), new plots seem to
# vanish — but nothing is lost: the httpgd server (the real device) keeps the
# full plot history; the window is just a view. To get it back, reopen the
# viewer at httpgd::hgd_url() — e.g. run the system2() call below by hand, or
# httpgd::hgd_browse() for a regular browser tab. If this bites often, factor
# the launcher into a `plots()` helper, or use a fixed port/token
# (hgd(port = ..., token = ...)) and bind a shell alias/keybinding to the URL.
if (interactive() && requireNamespace("httpgd", quietly = TRUE)) {
  options(device = function(...) {
    httpgd::hgd(silent = TRUE)
    system2("chromium",
      c("--enable-features=UseOzonePlatform,WaylandWindowDecorations",
        "--ozone-platform-hint=auto",
        paste0("--app=", httpgd::hgd_url())),
      stdout = FALSE, stderr = FALSE, wait = FALSE)
  })
}
